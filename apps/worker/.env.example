# Worker (apps/worker) environment. Copy to `apps/worker/.env` and fill in.
# `.env` is gitignored — never commit real keys.

# Supabase — server-side. Uses the new-scheme SECRET key (sb_secret_…), which
# bypasses RLS to write ledger rows. Keep it secret; never in the repo or browser.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# Agent identity (the agent_id used across the ledger).
AGENT_ID=agent-0

# Seed economy (USD) — see brief §4.
SEED_USD=20
RENT_PER_HOUR_USD=0.07

# Heartbeat cadence in ms. 1800000 = 30 min (production). Lower it for local testing.
TICK_INTERVAL_MS=1800000

# 0 = run forever (production). Set > 0 to stop after N ticks (local verification).
MAX_TICKS=0

# CoinMarketCap — optional for the heartbeat, required for data calls. Free first
# month at https://pro.coinmarketcap.com/account (promo: hobbyist_1st_month_free).
CMC_API_KEY=
CMC_API_BASE=https://pro-api.coinmarketcap.com
CMC_DATA_COST_USD=0.01

# Anthropic — optional for the heartbeat, required for the inner reason-and-act loop.
# https://console.anthropic.com → API Keys. Loop defaults to the cheap Haiku model.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
AGENT_MAX_ITERATIONS=6
GAS_PER_SWAP_USD=0.15

# Paper-trade friction + the ≥1-trade/day floor (86400000 = 24h; 0 disables).
SWAP_FEE_RATE=0.0025
SLIPPAGE=0.001
TRADE_FLOOR_MS=86400000

# Chain for trade explorer links (BscScan). mainnet | testnet.
BSC_NETWORK=mainnet

# x402-gated sizing skill (#10). Leave SKILL_URL unset to size in-process.
# When set, the agent pays its own skill to think (an x402_fee ledger expense).
# SKILL_URL=http://localhost:8788
SKILL_CALL_COST_USD=0.01
# Payer address for x402 settlement (BSC). Placeholder until #14 funds the wallet.
X402_PAYER=0x0000000000000000000000000000000000000000
