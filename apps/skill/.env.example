# Skill (apps/skill) environment. Copy to `apps/skill/.env` and fill in.
# `.env` is gitignored — never commit real keys.

# Port for the x402-gated Solvency-Aware Sizing endpoint.
SKILL_PORT=8788

# x402 payment requirements. We own these — settlement is on BSC, not Base.
# Price is in atomic units of X402_ASSET; 18-decimal BSC stablecoin → 0.01 = 1e16.
X402_NETWORK=bsc
X402_ASSET=USDT-BSC
X402_PRICE_ATOMIC=10000000000000000
# Treasury address payments settle to. Pinned for real in #14.
X402_PAY_TO=0x0000000000000000000000000000000000000000
