# Web dashboard (apps/web) — public, read-only. Uses the new-scheme PUBLISHABLE
# key (sb_publishable_…), which respects RLS. Next inlines NEXT_PUBLIC_* at build.
# Copy to apps/web/.env.local (gitignored).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
